DATABASE_URL=sqlite:////data/db/teamtracks.db
STORAGE_ROOT=/data/storage
CORS_ORIGINS=["http://localhost:5173"]
STEM_CACHE_MAX_AGE_SECONDS=315360000

# Replace both values before using a non-local installation.
PLATFORM_ADMIN_PASSWORD=change-me
AUTH_SECRET=development-auth-secret-change-me
PLATFORM_ADMIN_SESSION_HOURS=12
# Use true behind HTTPS. Keep false only for local HTTP development.
COOKIE_SECURE=false
